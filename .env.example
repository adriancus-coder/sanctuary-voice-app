OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-nano
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
TRANSCRIBE_RATE_LIMIT_WINDOW_MS=60000
TRANSCRIBE_RATE_LIMIT_MAX=40
# Live speech engine:
# - openai = default, uses OpenAI audio transcription chunks
# - azure = uses Microsoft Cognitive Services Speech SDK continuous streaming
# If Azure authentication/configuration fails at runtime, the admin UI falls back to OpenAI.
SPEECH_PROVIDER=openai

# Azure Speech resource key from Azure Portal > Speech service > Keys and Endpoint.
AZURE_SPEECH_KEY=

# Azure Speech region, for example: norwayeast, westeurope, eastus.
AZURE_SPEECH_REGION=
MASTER_ADMIN_PIN=
MASTER_MODERATOR_PIN=
MAIN_OPERATOR_PIN=
ADMIN_SESSION_SECRET=
ADMIN_SESSION_PERSISTENT=0
ADMIN_SESSION_MAX_AGE_HOURS=12
TRANSLATION_MONITOR_ENABLED=0
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:admin@sanctuaryvoice.com
LOG_DIR=
PUBLIC_BASE_URL=https://sanctuaryvoice.com
ADMIN_APP_BASE_URL=https://app.sanctuaryvoice.com
ADMIN_APP_HOSTNAMES=app.sanctuaryvoice.com,control.sanctuaryvoice.com,kontrol.sanctuaryvoice.com
COMMERCIAL_MODE=0
DEFAULT_ORG_ID=sanctuary-voice
DEFAULT_ORG_NAME=Sanctuary Voice
DEFAULT_ORG_PLAN=internal
DATA_DIR=
PORT=3000
